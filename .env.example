# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy to .env for local development
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS Configuration ─────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=default

# ── Terraform Secrets (passed as TF_VAR_ env vars or via -var flags) ─────────
# Required by `terraform apply` and `make deploy-dev`
TF_VAR_openai_api_key=sk-...
TF_VAR_news_api_key=your-newsapi-key   # Set to DISABLED to skip NewsAPI

# ── Terraform Remote State Backend ───────────────────────────────────────────
# Your S3 bucket name for Terraform state storage (see docs/DEPLOYMENT.md)
TF_STATE_BUCKET=news-summaries-tf-state-123456789012

# ── Local Lambda Testing ──────────────────────────────────────────────────────
# Used when running pytest locally (mocked by moto, not hitting real AWS)
STAGE=dev
S3_BUCKET_NAME=news-summaries-dev-content-123456789012
DYNAMODB_TABLE_NAME=news-summaries-dev-episodes
CLOUDFRONT_DOMAIN=d1234567890abcde.cloudfront.net
OPENAI_API_KEY=sk-...
NEWS_API_KEY=your-newsapi-key
LOG_LEVEL=DEBUG

# ── Podcast / RSS Feed ────────────────────────────────────────────────────────
# Set in terraform.tfvars — listed here for reference
PODCAST_TITLE=News Summaries
PODCAST_DESCRIPTION=Daily AI-powered news summaries
PODCAST_AUTHOR=Your Name
PODCAST_EMAIL=your@email.com
