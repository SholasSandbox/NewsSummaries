# ── AWS ───────────────────────────────────────────────────────────────────
# Region where the Lambda pipeline is deployed
AWS_REGION=us-east-1

# IAM credentials with permissions to:
#   lambda:InvokeFunction  → generate_summaries (Lambda 2)
#   s3:PutObject / GetObject → raw/, summaries/, unified/ prefixes
#   dynamodb:BatchGetItem  → episodes table (deduplication)
#   dynamodb:PutItem       → episodes table (unified summary metadata)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# S3 bucket used by the Lambda pipeline (matches S3_BUCKET_NAME in Lambda env vars)
S3_BUCKET_NAME=news-summaries-dev-content-123456789012

# DynamoDB table (matches DYNAMODB_TABLE_NAME in Lambda env vars)
DYNAMODB_TABLE_NAME=news-summaries-dev-episodes

# ARN or name of the generate_summaries Lambda function (Lambda 2)
GENERATE_SUMMARIES_FUNCTION=news-summaries-dev-generate-summaries

# ── Firecrawl ─────────────────────────────────────────────────────────────
# API key from https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-...

# ── Anthropic ─────────────────────────────────────────────────────────────
# API key from https://console.anthropic.com/ (Sonnet 4.5 / Sonnet 4.6)
ANTHROPIC_API_KEY=sk-ant-...

# Override the default Claude model (optional — defaults to claude-sonnet-4-5)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ── OpenAI ────────────────────────────────────────────────────────────────
# Used for text-embedding-3-small (1536-dim) stored with unified summary in S3
OPENAI_API_KEY=sk-...
