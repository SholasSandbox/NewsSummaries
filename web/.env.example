# ── Supabase ──────────────────────────────────────────────────────────────
# Project URL from your Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Service-role key (has full DB access; keep server-side only – never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Firecrawl ─────────────────────────────────────────────────────────────
# API key from https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-...

# ── Anthropic ─────────────────────────────────────────────────────────────
# API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Override the default Claude model (optional)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ── OpenAI ────────────────────────────────────────────────────────────────
# Used for text-embedding-3-small (1536-dim vectors stored in Supabase)
OPENAI_API_KEY=sk-...
