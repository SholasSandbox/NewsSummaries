# ── AWS (for invoking existing Lambda functions and reading/writing S3) ────
# Region where the Lambda pipeline is deployed
AWS_REGION=us-east-1

# IAM credentials with permissions to:
#   lambda:InvokeFunction  → generate_summaries
#   s3:PutObject           → raw/{date}/{hash}.json
#   s3:GetObject           → summaries/{date}/{hash}.json
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# S3 bucket used by the Lambda pipeline (matches S3_BUCKET_NAME in Lambda env vars)
S3_BUCKET_NAME=news-summaries-dev-content-123456789012

# ARN or name of the generate_summaries Lambda function (Lambda 2)
GENERATE_SUMMARIES_FUNCTION=news-summaries-dev-generate-summaries

# ── Supabase ──────────────────────────────────────────────────────────────
# Project URL from your Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Service-role key (has full DB access; keep server-side only – never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Firecrawl ─────────────────────────────────────────────────────────────
# API key from https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-...

# ── Anthropic ─────────────────────────────────────────────────────────────
# API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Override the default Claude model (optional)
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ── OpenAI ────────────────────────────────────────────────────────────────
# Used for text-embedding-3-small (1536-dim vectors stored in Supabase)
OPENAI_API_KEY=sk-...
